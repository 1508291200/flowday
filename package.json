{
  "name": "flowday",
  "version": "1.0.0",
  "description": "FlowDay - 智能日程管理工具，支持思维导图、列表、筛选三种视图",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "check": "pnpm type-check && pnpm lint"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.1.3",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "dexie": "^3.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.11.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  },
  "keywords": [
    "schedule",
    "task-management",
    "mindmap",
    "productivity"
  ],
  "author": "FlowDay Team",
  "license": "MIT"
}
